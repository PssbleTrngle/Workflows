{
  "name": "@pssbletrngle/github-meta-generator",
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./meta": "./dist/meta.json"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "bun run gen:meta && bun run gen:templates",
    "gen:meta": "bun run scripts/meta.ts",
    "gen:templates": "bun run scripts/templates.ts",
    "dev": "bun run scripts/watch.ts",
    "lint": "eslint {src,scripts,tests}",
    "format": "biome format --write {src,scripts,tests}",
    "test": "bun test"
  },
  "dependencies": {
    "@pssbletrngle/workflows-configs": "workspace:*",
    "@pssbletrngle/workflows-types": "workspace:*",
    "@pssbletrngle/workflows-shared": "workspace:*",
    "@types/bun": "latest",
    "handlebars": "^4.7.8",
    "prettier": "^3.6.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}