// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`minecraft workflow generation generates workflows with uploads: release workflow with all uploads 1`] = `
"# <meta>
#    <source>@pssbletrngle/github-meta-generator</source>
#    <version>0.0.0-dev</version>
#    <timestamp>2025-01-01T00:00:00.000Z</timestamp>
#    <hash>f5af7cce0c537ed9</hash>
# </meta>

name: Release
on:
  release:
    types: [published]

env:
  CI: true

jobs:
  build:
    runs-on: ubuntu-latest
    timeout-minutes: 20
    permissions:
      contents: read
      packages: write
    steps:
      - uses: actions/checkout@v4
        with:
          lfs: true

      - uses: actions/setup-java@v4
        with:
          java-version: 21
          distribution: temurin

      - uses: gradle/actions/setup-gradle@v4
        with:
          cache-read-only: \${{ github.event_name != 'push' }}

      - name: Build and upload
        run: ./gradlew build publish
        env:
          MODRINTH_TOKEN: \${{ secrets.MODRINTH_TOKEN }}
          CURSEFORGE_TOKEN: \${{ secrets.CURSEFORGE_TOKEN }}
          CHANGELOG: \${{ github.event.release.body }}
          RELEASE_VERSION: \${{ github.event.release.tag_name }}
          GITHUB_TOKEN: \${{ secrets.GITHUB_TOKEN }}
          NEXUS_USER: \${{ secrets.NEXUS_USER }}
          NEXUS_TOKEN: \${{ secrets.NEXUS_TOKEN }}
"
`;
