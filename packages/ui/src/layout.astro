---
import Indicator from "./components/Indicator.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Workflows Dashboard</title>
  </head>
  <body
    hx-ext="json-enc-custom,response-targets,sse,json-enc"
    hx-indicator="#loading-indicator"
    sse-connect="/metadata/api/sse"
  >
    <Indicator />
    <main>
      <slot />
    </main>
  </body>

  <style is:global>
    :root {
      --accent: #7e56c2;
      --text: #ddd;
      --bg-1: #1e2129;
      --bg-2: #303644;
    }

    html,
    body {
      margin: 0;
      padding: 0;

      background: var(--bg-1);
      color: var(--text);
      font-family: sans-serif;

      ::selection {
        background: var(--accent);
      }
    }

    main {
      padding: 1em 0;
      display: grid;
      justify-content: center;
    }

    button {
      cursor: pointer;
      user-select: none;

      &:hover {
        filter: brightness(110%);
      }

      &:disabled {
        filter: opacity(90%);
        cursor: not-allowed;

        &[data-disabled-by-htmx] {
          cursor: wait;
        }

        &:hover {
          filter: brightness(110%), opacity(90%);
        }
      }
    }

    form {
      accent-color: var(--accent);

      input,
      button,
      select {
        border: none;
        border-radius: 0.2em;
        outline: 0px solid var(--accent);
        outline-offset: 2px;
        transition:
          outline 0.1s ease,
          filter 0.1s ease;

        &:focus-visible {
          outline-width: 2px;
        }
      }

      input,
      button,
      option {
        background: #353a47;
        color: #ddd;
      }

      select {
        appearance: base-select;
        background: transparent;

        &::picker(select) {
          appearance: base-select;
        }
      }

      select[multiple] {
        overflow: hidden;
      }

      option {
        padding: 0.5em;

        &:checked {
          background: #565e72;
        }
      }

      input,
      button {
        padding: 1em;
      }

      label {
        font-style: italic;
        opacity: 0.5;
      }

      button[type="submit"] {
        background: var(--accent);
      }

      #error {
        &:not(:empty) {
          background: #f024;
          outline: solid 1px #f02;
          outline-offset: 2px;
        }

        border-radius: 0.2em;
        padding: 0.2em;
        margin: 0;
        text-align: center;
      }
    }

    dialog {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);

      background: var(--bg-2);
      color: var(--text);
      border: none;

      box-shadow: #0002 0 10px 20px;
    }

    a {
      color: var(--accent);
      text-decoration: none;

      transition: color 0.1s ease;

      &:hover {
        color: color-mix(in srgb, var(--accent) 80%, #fff);
        text-decoration: underline;
      }
    }
  </style>
</html>

<script>
  import "htmx-ext-json-enc";
  import "htmx-ext-sse";
  import "htmx.org";
  import type { HtmxResponseInfo } from "htmx.org";

  type BeforeSwapEvent = Event & {
    detail: HtmxResponseInfo & {
      swapOverride?: string;
    };
  };

  document.addEventListener(
    "htmx:beforeSwap",
    ({ detail }: BeforeSwapEvent) => {
      const override =
        detail.requestConfig.elt.getAttribute("hx-target-override");

      if (override && document.querySelector(override)) {
        detail.swapOverride = override;
      }
    },
  );
</script>
