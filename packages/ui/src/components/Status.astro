---
import { createPath, createTopic } from "@pssbletrngle/workflows-shared/topic";
import type { RepoSearchWithBranch } from "@pssbletrngle/workflows-types";
import type {
  Check,
  Checks,
  RepositoryStatus,
} from "@pssbletrngle/workflows-types/metadata";
import Refresh from "./Refresh.astro";

const icons: Record<RepositoryStatus, string> = {
  failed: "🧨",
  "opened-pr": "🙏",
  "up-to-date": "✅",
  running: "🏃‍♂️",
};

const messages: Record<RepositoryStatus | Check, string> = {
  failed: "Failed",
  "opened-pr": "Pull Request opened",
  "up-to-date": "Up to date",
  running: "Running...",
  not_blocked: "a ruleset is blocking the app",
  protected: "the branch is not protected",
};

type Props = {
  subject: RepoSearchWithBranch;
  status: RepositoryStatus;
  checks?: Checks;
};

const { subject, status, checks = {} } = Astro.props;

const icon = icons[status];

const warnings = Object.entries(checks)
  .filter(([_, value]) => value === false)
  .map(([key]) => messages[key as Check]);
---

<span
  class="status"
  hx-trigger={`sse:${createTopic("status_updated", subject)}`}
  hx-get={`/metadata/partial/${createPath(subject, "status")}`}
  hx-swap="outerHTML"
>
  <span>{subject.branch}</span>
  <span class="value">
    <span title={messages[status]}>{icon}</span>
    {warnings.length > 0 && <span title={warnings.join(", ")}>⚠️</span>}
  </span>
  <Refresh repo={subject} disabled={status === "running"} />
</span>

<style scoped>
  .status {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 1em;
  }

  .value {
    background: #fff4;
    padding: 0.5em;
    border-radius: 9999px;
    text-align: center;

    cursor: help;
  }
</style>
