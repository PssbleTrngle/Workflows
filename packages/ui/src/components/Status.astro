---
import {
  createTopic,
  type RepoSearchWithBranch,
} from "@pssbletrngle/webhooks-types";
import type { RepositoryStatus } from "@pssbletrngle/webhooks-types/metadata";
import Refresh from "./Refresh.astro";

const icons: Record<RepositoryStatus, string> = {
  failed: "🧨",
  "opened-pr": "🙏",
  "up-to-date": "✅",
  running: "🏃‍♂️",
};

const { subject, value } = Astro.props as {
  subject: RepoSearchWithBranch;
  branch: string;
  value: RepositoryStatus;
};

const icon = icons[value];

const topic = createTopic(subject, "status");
---

<span
  class="status"
  hx-trigger={`sse:${topic}`}
  hx-get={`/metadata/partial/${topic}`}
  hx-swap="outerHTML"
>
  <span>{subject.base}</span>
  <span class="value">{value} {icon}</span>
  <Refresh repo={subject} disabled={value === "running"} />
</span>

<style scoped>
  .status {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 1em;
  }

  .value {
    background: #fff4;
    padding: 0.5em;
    border-radius: 9999px;
    text-align: center;
  }
</style>
