---
import type { Notifier } from "@pssbletrngle/workflows-types/metadata";
import type { HTMLAttributes } from "astro/types";
import AddRuleButton from "./AddRuleButton.astro";
import AddWebhookButton from "./AddWebhookButton.astro";
import RuleInput from "./RuleInput.astro";
import RulesInput from "./RulesInput.astro";
import WebhookInput from "./WebhookInput.astro";
import WebhooksInput from "./WebhooksInput.astro";

export type Props = HTMLAttributes<"form"> & {
  value?: Notifier;
};

const { value, ...props } = Astro.props;
---

<form hx-disabled-elt="find button" empty-as-null="true" {...props}>
  <input name="name" placeholder="Name" type="text" value={value?.name} />

  <RulesInput path="rules" value={value?.rules} />
  <RulesInput path="exclude" value={value?.exclude} />
  <WebhooksInput value={value?.discordWebhooks} />

  <template id="rule-input-template">
    <RuleInput path="{{ path }}[{{ index }}]" />
    <AddRuleButton path="{{ path }}" index="++{{ index }}" />
  </template>

  <template id="webhook-input-template">
    <WebhookInput path="{{ index }}" />
    <AddWebhookButton index="++{{ index }}" />
  </template>

  <button type="submit">Save</button>
</form>

<style scoped>
  form {
    display: grid;
    gap: 1em;

    width: min(800px, 95vw);
  }
</style>
