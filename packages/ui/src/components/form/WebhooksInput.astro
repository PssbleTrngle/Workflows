---
import AddWebhookButton from "./AddWebhookButton.astro";
import WebhookInput from "./WebhookInput.astro";

export type Props = { value?: string[] };

const { value = [] } = Astro.props;
---

<label>Webhooks</label>

{value.map((it, i) => <WebhookInput value={it} path={i.toString()} />)}

<AddWebhookButton index={value.length} />
