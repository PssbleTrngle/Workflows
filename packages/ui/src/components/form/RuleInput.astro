---
import type { RepositoryRule } from "@pssbletrngle/workflows-types/metadata";

export type Props = { value?: RepositoryRule; path: string };

const { value, path } = Astro.props;
---

<section class="rule-input">
  <input
    type="text"
    placeholder="Repository Name"
    name={`${path}[repo]`}
    value={value?.repo}
  />
  <input
    type="text"
    placeholder="Repository Owner"
    name={`${path}[owner]`}
    value={value?.owner}
  />
  <input
    type="text"
    placeholder="Branch"
    name={`${path}[branch]`}
    value={value?.branch}
  />

  <button hx-on:click="this.closest('.rule-input').remove()">🗑️</button>
</section>

<style scoped>
  .rule-input {
    display: grid;
    grid-template-columns: repeat(3, 1fr) 100px;
    gap: 1em;
  }
</style>
