---
import Select from "@/components/form/Select.astro";

type FilterValues = {
  owner: string[];
  gradleHelper: string[];
  loader: string[];
  version: string[];
};

const { owner, gradleHelper, loader, version } =
  await Astro.locals.api.request<FilterValues>("repository/filters");
---

<form
  hx-post="/partial/search"
  hx-target="next .repositories"
  hx-trigger="change"
  empty-as-null="true"
>
  <Select options={owner} name="owner" allowNull>Owner</Select>
  <Select options={version} name="version" allowNull>Minecraft Version</Select>
  <Select options={loader} name="loader" allowNull>Mod Loader</Select>
  <Select options={gradleHelper} name="gradleHelper" allowNull>
    Gradle Helper
  </Select>

  <label for="failedChecks">Has failed checks?</label>
  <input type="checkbox" name="failedChecks" id="failedChecks" />
</form>

<style scoped>
  form {
    margin-bottom: 2em;

    display: grid;
    grid-template-rows: repeat(2, 1fr);
    grid-auto-flow: column;
    column-gap: 3em;
  }
</style>
