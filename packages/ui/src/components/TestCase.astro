---
import { formatAgo } from "@/lib/time";
import {
  createId,
  createPath,
  createTopic,
} from "@pssbletrngle/workflows-shared/topic";
import { notNull } from "@pssbletrngle/workflows-shared/util";
import type {
  RepoSearch,
  RepoSearchWithBranch,
} from "@pssbletrngle/workflows-types";
import type {
  TestedSetup,
  TestStatus,
} from "@pssbletrngle/workflows-types/metadata";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"li"> & {
  repo: RepoSearch;
} & TestedSetup;

function statusIcon(status: TestStatus): string {
  switch (status) {
    case "in_progress":
      return "🏃‍♂️";
    case "waiting":
    case "queued":
    case "pending":
    case "requested":
      return "⏳";

    case "action_required":
    case "timed_out":
      return "⚠️";

    case "failure":
      return "🔥";

    case "success":
      return "✅";

    default:
      return "❓";
  }
}

const missingStatus: TestStatus = "missing";

const { repo, setup, tests, ...props } = Astro.props;

const subject: RepoSearchWithBranch = { ...repo, branch: setup.ref };
const url = `https://github.com/${subject.owner}/${subject.repo}/tree/${subject.branch}`;

const cases = Object.entries(tests)
  .map(([key, result]) => {
    if (!result) return { key, testStatus: missingStatus };
    const testStatus = result.conclusion ?? result.status;
    const date = new Date(result.at);
    return { key, testStatus, date, link: result.link };
  })
  .filter(notNull);
---

<li
  hx-trigger={`sse:${createTopic("branch_updated", subject)}`}
  hx-get={`/partial/${createPath(subject, "test-case")}`}
  hx-swap="outerHTML"
  class:list={["test-case", props.class]}
  id={createId("test-case", subject)}
  {...props}
>
  <a href={url}>{setup.type}@{setup.version}</a>
  {
    cases.map(({ key, date, testStatus, link }) => (
      <div>
        <span class="status" title={`${key} ${testStatus}`}>
          {statusIcon(testStatus)}
        </span>
        {date ? (
          <a
            href={link}
            title={`${date.toLocaleDateString()} ${date.toLocaleTimeString()}`}
          >
            {formatAgo(date)}
          </a>
        ) : (
          <i>never</i>
        )}
      </div>
    ))
  }
</li>

<style scoped>
  .test-case {
    background: var(--bg-2);

    border-radius: 10px;
    padding: 1em;

    display: grid;
    grid-template-columns: subgrid;

    grid-column: span 3;

    align-items: center;

    .status {
      user-select: none;
      cursor: help;
    }

    i {
      user-select: none;
    }
  }
</style>
