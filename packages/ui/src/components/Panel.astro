---
import { createId } from "@pssbletrngle/workflows-shared/topic";
import type { Repository } from "@pssbletrngle/workflows-types/metadata";
import type { HTMLAttributes } from "astro/types";
import Refresh from "./Refresh.astro";
import Status from "./Status.astro";

type Props = Repository & HTMLAttributes<"li">;

const { owner, repo, branches, ...props } = Astro.props;
const url = `https://github.com/${owner}/${repo}`;
---

<li
  {...props}
  class:list={["panel", props.class]}
  id={createId("repo", { owner, repo })}
>
  <a class="title" href={url}>
    {owner}/{repo}
  </a>
  <Refresh repo={{ owner, repo }} />
  <ul class="branches">
    {
      branches.map(
        (branch) =>
          branch.status && (
            <li>
              <Status
                subject={{ owner, repo, branch: branch.ref }}
                status={branch.status}
              />
            </li>
          ),
      )
    }
  </ul>
</li>

<style scoped>
  .panel {
    background: #0001;
    width: 350px;
    height: 150px;
    border-radius: 10px;

    display: grid;
    grid-template:
      "title refresh"
      "branches branches"
      / 1fr auto;

    padding: 1em;
  }

  .branches {
    list-style: none;
    grid-area: branches;
    padding: 0;

    li:not(:first-child) {
      margin-top: 0.5em;
    }
  }

  .title {
    color: var(--text);
  }
</style>
