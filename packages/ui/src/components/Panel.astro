---
import type { RepoSearch, Repository } from "@pssbletrngle/webhooks-types";
import type { RepositoryStatus } from "@pssbletrngle/webhooks-types/metadata";
import Status from "./Status.astro";

type Props = {
  repo: Repository;
  status?: Record<string, RepositoryStatus>;
};

const { status = {}, repo } = Astro.props as Props;

const subject: RepoSearch = {
  owner: repo.owner.login,
  repo: repo.name,
};
---

<li class="panel">
  <a class="title" href={repo.html_url}>
    {repo.full_name}
  </a>
  {
    Object.entries(status).map(([base, status]) => (
      <Status subject={{ ...subject, base }} value={status} />
    ))
  }
</li>

<style scoped>
  .panel {
    background: #0001;
    width: 350px;
    height: 150px;
    border-radius: 10px;

    display: grid;
    grid-template-rows: repeat(auto-fit, 3em);

    padding: 1em;
  }

  .title {
    color: var(--text);
  }
</style>
