---
import { createId } from "@pssbletrngle/workflows-shared/topic";
import type { RepositoryStatusResult } from "@pssbletrngle/workflows-types/metadata";
import type { HTMLAttributes } from "astro/types";
import Refresh from "./Refresh.astro";
import Status from "./Status.astro";

type Props = RepositoryStatusResult & HTMLAttributes<"li">;

const { status = {}, subject, ...props } = Astro.props;
const url = `https://github.com/${subject.owner}/${subject.repo}`;
---

<li
  {...props}
  class:list={["panel", props.class]}
  id={createId("repo", subject)}
>
  <a class="title" href={url}>
    {subject.owner}/{subject.repo}
  </a>
  <Refresh repo={subject} />
  <ul class="branches">
    {
      Object.entries(status).map(([branch, props]) => (
        <li>
          <Status subject={{ ...subject, branch }} {...props} />
        </li>
      ))
    }
  </ul>
</li>

<style scoped>
  .panel {
    background: #0001;
    width: 350px;
    height: 150px;
    border-radius: 10px;

    display: grid;
    grid-template:
      "title refresh"
      "branches branches"
      / 1fr auto;

    padding: 1em;
  }

  .branches {
    list-style: none;
    grid-area: branches;
    padding: 0;

    li:not(:first-child) {
      margin-top: 0.5em;
    }
  }

  .title {
    color: var(--text);
  }
</style>
