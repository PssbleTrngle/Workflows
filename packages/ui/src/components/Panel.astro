---
import {
  createId,
  createPath,
  createTopic,
} from "@pssbletrngle/workflows-shared/topic";
import type { Repository } from "@pssbletrngle/workflows-types/metadata";
import type { HTMLAttributes } from "astro/types";
import Refresh from "./Refresh.astro";
import Status from "./Status.astro";

type Props = Repository & HTMLAttributes<"li">;

const { owner, repo, branches, icon, ...props } = Astro.props;
const url = `https://github.com/${owner}/${repo}`;
---

<li
  {...props}
  hx-trigger={`sse:${createTopic("repository_updated", Astro.props)}`}
  hx-get={`/metadata/partial/${createPath(Astro.props, "panel")}`}
  hx-swap="outerHTML"
  class:list={["panel", props.class]}
  id={createId("repo", { owner, repo })}
>
  {icon && <img alt="" class="icon" src={icon} />}
  <a class="title" href={url}>
    {owner}/{repo}
  </a>
  <Refresh class="refresh" repo={{ owner, repo }} />
  <ul class="branches">
    {
      branches.map(
        (branch) =>
          branch.status && (
            <li>
              <Status
                subject={{ owner, repo, branch: branch.ref }}
                status={branch.status}
              />
            </li>
          ),
      )
    }
  </ul>
</li>

<style scoped>
  .panel {
    background: #0001;
    width: 350px;
    height: 250px;
    border-radius: 10px;

    display: grid;
    grid-template:
      "icon title refresh"
      "branches branches branches"
      / 2em 1fr 2em;

    gap: 1em;
    padding: 1em;
  }

  .branches {
    list-style: none;
    grid-area: branches;
    padding: 0;

    li:not(:first-child) {
      margin-top: 0.5em;
    }
  }

  .title {
    color: var(--text);
    grid-area: title;
  }

  .refresh {
    grid-area: refresh;
  }

  .icon {
    aspect-ratio: 1 / 1;
    object-fit: contain;
    width: 2em;
    grid-area: icon;

    border-radius: 5px;
  }
</style>
