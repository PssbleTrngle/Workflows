---
import type { Repository } from "@pssbletrngle/webhooks-types";

const { repo } = Astro.props as { repo: Repository };
---

<form
  hx-post="/metadata/action/refresh"
  hx-target="closest .status"
  hx-swap="outerHTML"
>
  <input type="hidden" name="owner" value={repo.owner.login} />
  <input type="hidden" name="repo" value={repo.name} />

  <button title="Refresh">🔄</button>
</form>

<style scoped>
  button {
    background: transparent;
    padding: 0;
    font-size: 1.5em;
  }
</style>
