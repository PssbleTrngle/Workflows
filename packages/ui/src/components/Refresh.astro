---
import type {
  RepoSearch,
  RepoSearchWithBranch,
} from "@pssbletrngle/workflows-types";
import type { HTMLAttributes } from "astro/types";

type Props = {
  repo: RepoSearchWithBranch | RepoSearch;
  disabled?: boolean;
} & HTMLAttributes<"form">;

const { repo, disabled, ...props } = Astro.props;
---

<form
  hx-post="/metadata/api/refresh"
  hx-swap="none"
  hx-disabled-elt="find button"
  {...props}
>
  <input type="hidden" name="owner" value={repo.owner} />
  <input type="hidden" name="repo" value={repo.repo} />
  {
    "branch" in repo && (
      <input type="hidden" name="branch" value={repo.branch} />
    )
  }
  <button title="Refresh" disabled={disabled}>🔄</button>
</form>

<style scoped>
  button {
    background: transparent;
    padding: 0;
    font-size: 1.5em;

    &:disabled {
      filter: grayscale();
    }
  }
</style>
