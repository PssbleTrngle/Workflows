---
import type { RepoSearchWithBranch } from "@pssbletrngle/webhooks-types";

const { repo, disabled } = Astro.props as {
  repo: RepoSearchWithBranch;
  disabled?: boolean;
};
---

<form
  hx-post="/metadata/action/refresh"
  hx-target="closest .status"
  hx-swap="none"
  hx-disabled-elt="find button"
>
  <input type="hidden" name="owner" value={repo.owner} />
  <input type="hidden" name="repo" value={repo.repo} />
  <input type="hidden" name="branch" value={repo.base} />

  <button title="Refresh" disabled={disabled}>🔄</button>
</form>

<style scoped>
  button {
    background: transparent;
    padding: 0;
    font-size: 1.5em;

    &:disabled {
      filter: grayscale();
    }
  }
</style>
