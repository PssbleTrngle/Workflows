---
import type {
  RepositoryStatusResult,
  StatusResult,
} from "@pssbletrngle/workflows-types/metadata";
import CheckButton from "../components/CheckButton.astro";
import Panel from "../components/Panel.astro";
import Layout from "../layout.astro";

const { api } = Astro.locals;

// TODO validate?
const page = Number.parseInt(Astro.url.searchParams.get("page") || "1");

async function listStatuses(): Promise<RepositoryStatusResult[]> {
  const entries = await api.request<StatusResult[]>(`status?page=${page}`);

  const map: Record<string, Record<string, Omit<StatusResult, "search">>> = {};

  entries.forEach(({ search, ...status }) => {
    const repository = `${search.owner}/${search.repo}`;
    if (!(repository in map)) map[repository] = {};
    map[repository][search.branch] = status;
  });

  return Object.entries(map).map(([key, status]) => {
    const [owner, repo] = key.split("/");
    return {
      status,
      subject: { owner, repo },
    };
  });
}

const statuses = await listStatuses();
---

<Layout>
  <CheckButton />
  <ul class="status-list">
    {statuses.map((props) => <Panel {...props} />)}
  </ul>
</Layout>

<style scoped>
  ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;

    width: 90vw;
    max-width: 1600px;

    gap: 20px;
    padding: 10px;
  }
</style>
