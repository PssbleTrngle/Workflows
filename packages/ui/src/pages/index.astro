---
import type { Page } from "@pssbletrngle/workflows-types";
import type { Repository } from "@pssbletrngle/workflows-types/metadata";
import CheckButton from "../components/CheckButton.astro";
import Panel from "../components/Panel.astro";
import Layout from "../layout.astro";

const { api } = Astro.locals;

// TODO validate?
const page = Number.parseInt(Astro.url.searchParams.get("page") || "1");

// todo pass query params?
const { entries: repositories } = await api.request<Page<Repository>>(
  `repository?page=${page}`,
);
---

<Layout>
  <CheckButton />
  <ul class="status-list">
    {repositories.map((props) => <Panel {...props} />)}
  </ul>
</Layout>

<style scoped>
  ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;

    width: 90vw;
    max-width: 1600px;

    gap: 20px;
    padding: 10px;
  }
</style>
