---
import type {
  RepositoryStatus,
  StatusResult,
} from "@pssbletrngle/workflows-types/metadata";
import Panel from "../components/Panel.astro";
import Layout from "../layout.astro";

const { api, octokit } = Astro.locals;

// TODO validate?
const page = Number.parseInt(Astro.url.searchParams.get("page") || "1");

async function listStatuses() {
  const entries = await api.request<StatusResult[]>(`status?page=${page}`);

  const map: Record<string, Record<string, RepositoryStatus>> = {};

  entries.forEach(({ search, status }) => {
    const repository = `${search.owner}/${search.repo}`;
    if (!(repository in map)) map[repository] = {};
    map[repository][search.branch] = status;
  });

  return map;
}

async function listRepos() {
  const { data } = await octokit.rest.repos.listForAuthenticatedUser({
    per_page: 20,
    page,
    sort: "pushed",
  });

  return data;
}

const [repos, statuses] = await Promise.all([listRepos(), listStatuses()]);
---

<Layout>
  <h1>Welcome</h1>
  <ul>
    {
      repos.map((repo) => (
        <Panel repo={repo} status={statuses[repo.full_name]} />
      ))
    }
  </ul>
</Layout>

<style scoped>
  ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;

    width: 90vw;
    max-width: 1600px;

    gap: 20px;
    padding: 10px;
  }
</style>
