---
import StatusComponent from "@/components/Status.astro";
import { ApiError } from "@/lib/api";
import { createPath } from "@pssbletrngle/workflows-shared/topic";
import { type RepoSearchWithBranch } from "@pssbletrngle/workflows-types";
import type { Branch } from "@pssbletrngle/workflows-types/metadata";

export const partial = true;

const { api } = Astro.locals;

const subject = Astro.params as RepoSearchWithBranch;

const { status, checks } = await api.request<Branch>(
  `repository/${createPath(subject)}`,
);

if (!status) throw new ApiError("branch has no status", 404);
---

<StatusComponent status={status} checks={checks} subject={subject} />
