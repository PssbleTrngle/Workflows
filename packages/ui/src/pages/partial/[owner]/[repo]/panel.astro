---
import PanelComponent from "@/components/Panel.astro";
import { createPath } from "@pssbletrngle/workflows-shared/topic";
import type { RepoSearch } from "@pssbletrngle/workflows-types";
import type { Repository } from "@pssbletrngle/workflows-types/metadata";

const subject = Astro.params as RepoSearch;
const { api } = Astro.locals;

const repository = await api.request<Repository>(
  `repository/${createPath(subject)}`,
);
---

<PanelComponent {...repository} />
