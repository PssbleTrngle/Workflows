---
import AddRuleButton from "@/components/form/AddRuleButton.astro";
import RuleInput from "@/components/RuleInput.astro";
import { ApiError } from "@/lib/api";

const { searchParams } = new URL(Astro.request.url);
const path = searchParams.get("path") ?? "";
const index = Number.parseInt(searchParams.get("index") ?? "0");

if (isNaN(index) || index < 0)
  throw new ApiError("'index' must be a positive number", 400);

Astro.response.headers.set("Cache-Control", "max-age=1");
---

<RuleInput path={`${path}[${index}]`} />

<AddRuleButton path={path} index={index + 1} />
