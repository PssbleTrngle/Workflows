---
import TestSetups from "@/components/TestSetups.astro";
import Layout from "@/layout.astro";
import { fetchTestSetups } from "@/lib/testResults";
import type { RepoSearch } from "@pssbletrngle/workflows-types";
import type { TestSetup } from "@pssbletrngle/workflows-types/metadata";

// TODO not hard-coded
const subject: RepoSearch = {
  owner: "PssbleTrngle",
  repo: "TestMod",
};

const groupingKeys: Array<keyof TestSetup> = ["version", "type"];
const defaultGroupBy: keyof TestSetup = "version";

const setups = await fetchTestSetups(subject, Astro.locals);
---

<Layout>
  <h1>Test Mod Result</h1>

  <form>
    <label for="groupBy">Group by:</label>

    <select
      hx-post="/metadata/partial/cases"
      name="groupBy"
      hx-trigger="change"
      hx-target="next .groups"
      hx-swap="outerHTML"
    >
      {
        groupingKeys.map((it) => (
          <option value={it} selected={it === defaultGroupBy}>
            {it}
          </option>
        ))
      }
    </select>
    <input name="owner" value={subject.owner} type="hidden" />
    <input name="repo" value={subject.repo} type="hidden" />
  </form>

  <TestSetups subject={subject} setups={setups} groupBy={defaultGroupBy} />
</Layout>

<style scoped>
  form,
  h1 {
    text-align: center;
  }
</style>
