---
import type { RepositoryStatus } from "@pssbletrngle/webhooks-types/metadata";
import Status from "../../components/Status.astro";

export const partial = true;

const { api } = Astro.locals;

// TODO csrf token?
// TODO validation?
const data = await Astro.request.formData();
const owner = data.get("owner") as string;
const repo = data.get("repo") as string;

const { status } = await api.submit<{ status: RepositoryStatus }>("refresh", [
  { owner, repo },
]);
---

<Status value={status} branch="main" />
