{
  "name": "@pssbletrngle/workflows-server",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint {src,scripts}",
    "format": "biome format --write {src,scripts}",
    "build": "bun build --outdir ./dist --target=bun --sourcemap=linked --env disable src/main.ts"
  },
  "peerDependencies": {
    "@octokit/oauth-app": "^8.0.3",
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/webhooks": "^14.2.0",
    "@types/express-serve-static-core": "^5.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@pssbletrngle/github-meta-generator": "workspace:*",
    "@pssbletrngle/workflows-configs": "workspace:*",
    "@pssbletrngle/workflows-events": "workspace:*",
    "@pssbletrngle/workflows-notifications": "workspace:*",
    "@pssbletrngle/workflows-persistance": "workspace:*",
    "@pssbletrngle/workflows-shared": "workspace:*",
    "@pssbletrngle/workflows-types": "workspace:*",
    "@pssbletrngle/workflows-ui": "workspace:*",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "octokit": "^5.0.5",
    "winston": "^3.19.0",
    "zod": "^4.1.12"
  }
}