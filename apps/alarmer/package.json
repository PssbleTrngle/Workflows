{
  "name": "@pssbletrngle/workflows-alarmer",
  "type": "module",
  "exports": {
    ".": "./src/main.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "biome format --write src",
    "build": "bun build --outdir ./dist --target=bun --sourcemap=linked --env disable src/main.ts --external=cpu-features"
  },
  "dependencies": {
    "@pssbletrngle/workflows-docker": "workspace:*",
    "@pssbletrngle/workflows-notifications": "workspace:*",
    "@pssbletrngle/workflows-persistance": "workspace:*",
    "@pssbletrngle/workflows-configs": "workspace:*",
    "@pssbletrngle/workflows-shared": "workspace:*",
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11",
    "node-cron": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}