{
  "name": "@pssbletrngle/workflows-consumer",
  "type": "module",
  "exports": {
    ".": "./src/main.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "eslint {src,tests}",
    "format": "biome format --write {src,tests}",
    "build": "bun build --outdir ./dist --target=node --sourcemap=linked --env disable src/main.ts --external=cpu-features"
  },
  "dependencies": {
    "@pssbletrngle/workflows-docker": "workspace:*",
    "@pssbletrngle/workflows-notifications": "workspace:*",
    "@pssbletrngle/workflows-events": "workspace:*",
    "@pssbletrngle/workflows-configs": "workspace:*",
    "@pssbletrngle/workflows-shared": "workspace:*",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}