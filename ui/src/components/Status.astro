---
import type { RepositoryStatus } from "@pssbletrngle/webhooks-types/metadata";

const { value } = Astro.props as {
  value: RepositoryStatus;
};
---

<span class="status">{value}</span>

<style scoped>
  .status {
    background: #fff4;
    padding: 0.5em;
    border-radius: 9999px;
    text-align: center;
  }
</style>
