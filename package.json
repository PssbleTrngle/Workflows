{
   "name": "@pssbletrngle/github-meta",
   "devDependencies": {
      "@biomejs/biome": "^2.3.4",
      "bun-git-hooks": "^0.3.1",
      "turbo": "^2.8.12"
   },
   "packageManager": "bun@1.3.10",
   "private": true,
   "scripts": {
      "dev": "turbo dev",
      "check": "turbo check-types lint test",
      "format": "turbo format",
      "build": "turbo build"
   },
   "git-hooks": {
      "pre-commit": "bun format",
      "pre-push": "bun check",
      "commit-msg": "true"
   },
   "workspaces": [
      "apps/*",
      "packages/*"
   ]
}